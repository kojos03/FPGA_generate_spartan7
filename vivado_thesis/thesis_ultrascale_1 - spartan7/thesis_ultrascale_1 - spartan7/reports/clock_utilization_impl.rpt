# Location of BUFG Primitives 
set_property LOC BUFGCTRL_X0Y0 [get_cells clk_o_OBUF_BUFG_inst]

# Location of IO Primitives which is load of clock spine
set_property LOC IOB_X0Y58 [get_cells clk_o_OBUF_inst]

# Location of clock ports
set_property LOC IOB_X0Y28 [get_ports clk]

# Clock net "clk_o_OBUF_BUFG" driven by instance "clk_o_OBUF_BUFG_inst" located at site "BUFGCTRL_X0Y0"
#startgroup
create_pblock {CLKAG_clk_o_OBUF_BUFG}
add_cells_to_pblock [get_pblocks  {CLKAG_clk_o_OBUF_BUFG}] [get_cells -filter { PRIMITIVE_GROUP != I/O && IS_PRIMITIVE==1 && PRIMITIVE_LEVEL !=INTERNAL && NAME!=clk_o_OBUF_inst} -of_object [get_pins -filter {DIRECTION==IN} -of_objects [get_nets -hierarchical -filter {PARENT=="clk_o_OBUF_BUFG"}]]]
resize_pblock [get_pblocks {CLKAG_clk_o_OBUF_BUFG}] -add {CLOCKREGION_X0Y0:CLOCKREGION_X0Y0 CLOCKREGION_X0Y1:CLOCKREGION_X0Y1 CLOCKREGION_X0Y2:CLOCKREGION_X0Y2 CLOCKREGION_X1Y0:CLOCKREGION_X1Y0 CLOCKREGION_X1Y1:CLOCKREGION_X1Y1 CLOCKREGION_X1Y2:CLOCKREGION_X1Y2}
#endgroup
